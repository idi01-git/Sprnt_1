// =============================================================================
// SPRINTERN — MVP Prisma Schema (18 Models)
// PostgreSQL 15+ | Prisma ORM 7 | Reduced from 32 tables
// Fresh migration — all existing dev data will be lost
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  student

  @@map("user_role")
}

enum AdminRole {
  super_admin
  admin
  reviewer

  @@map("admin_role")
}

enum StudyLevel {
  NINTH     @map("9th")
  TENTH     @map("10th")
  ELEVENTH  @map("11th")
  TWELFTH   @map("12th")
  COLLEGE_1 @map("College 1st Year")
  COLLEGE_2 @map("College 2nd Year")
  COLLEGE_3 @map("College 3rd Year")
  COLLEGE_4 @map("College 4th Year")
  GRADUATED @map("Graduated")

  @@map("study_level")
}

enum Branch {
  Chemical
  Civil
  Mechanical
  Electrical
  ECE
  CS_IT      @map("CS/IT")

  @@map("branch")
}

enum PaymentStatus {
  pending
  success
  failed
  refunded

  @@map("payment_status")
}

enum ReviewStatus {
  pending
  under_review
  approved
  rejected

  @@map("review_status")
}

enum GradeCategory {
  Distinction
  First_Class @map("First Class")
  Pass
  Fail

  @@map("grade_category")
}

enum ReferralStatus {
  pending
  completed
  rejected

  @@map("referral_status")
}

enum WithdrawalStatus {
  pending
  processing
  completed
  rejected

  @@map("withdrawal_status")
}

enum TransactionType {
  course_purchase
  referral_credit
  withdrawal
  refund
  manual_credit
  manual_debit

  @@map("transaction_type")
}

enum TransactionStatus {
  pending
  completed
  failed

  @@map("transaction_status")
}

enum DiscountType {
  fixed
  percentage

  @@map("discount_type")
}

enum WebhookStatus {
  success
  failed
  ignored

  @@map("webhook_status")
}

// =============================================================================
// SECTION 1: AUTHENTICATION & USERS
// =============================================================================

model User {
  id             String      @id @default(cuid())
  email          String      @unique @db.VarChar(255)
  hashedPassword String?     @map("hashed_password")
  name           String      @db.VarChar(200)
  phone          String?     @db.VarChar(20)
  dob            DateTime?   @db.Date
  studyLevel     StudyLevel? @map("study_level")
  avatarUrl      String?     @map("avatar_url")
  role           UserRole    @default(student)
  referralCode   String?     @unique @map("referral_code") @db.VarChar(30)
  // Removed: phone_verified, referral_code_active
  isSuspended    Boolean     @default(false) @map("is_suspended")
  referredBy     String?     @map("referred_by")
  walletBalance  Decimal     @default(0.00) @map("wallet_balance") @db.Decimal(10, 2)
  upiId          String?     @map("upi_id") @db.VarChar(100)
  emailVerified  Boolean     @default(false) @map("email_verified")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime?   @map("deleted_at") @db.Timestamptz()

  sessions           Session[]
  oauthAccounts      OAuthAccount[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  enrollments        Enrollment[]
  submissions        Submission[]
  referralsSent      Referral[]          @relation("referralsSent")
  referralsReceived  Referral[]          @relation("referralsReceived")
  withdrawalRequests WithdrawalRequest[]
  transactions       Transaction[]
  promocodeUsages    PromocodeUsage[]

  @@index([email])
  @@index([referralCode])
  @@index([referredBy])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model OAuthAccount {
  providerId     String   @map("provider_id") @db.VarChar(50)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  userId         String   @map("user_id")
  email          String   @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([providerId, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// =============================================================================
// SECTION 2: ADMIN ACCOUNTS
// =============================================================================

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash")
  role         AdminRole @default(reviewer)
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  adminSessions        AdminSession[]
  assignedSubmissions  Submission[]
  processedWithdrawals WithdrawalRequest[]
  createdPromocodes    Promocode[]
  grantedEnrollments   Enrollment[]
  adminTransactions    Transaction[]
  updatedSettings      SystemSetting[]

  @@index([email])
  @@index([isActive])
  @@map("admins")
}

model AdminSession {
  id        String   @id
  adminId   String   @map("admin_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz()

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

// =============================================================================
// SECTION 3: COURSES & CONTENT
// =============================================================================

model Course {
  id                   String    @id @default(cuid())
  courseId             String    @unique @map("course_id") @db.VarChar(50)
  courseName           String    @map("course_name") @db.VarChar(200)
  slug                 String    @unique @db.VarChar(200)
  affiliatedBranch     Branch    @map("affiliated_branch")
  coursePrice          Decimal   @default(299.00) @map("course_price") @db.Decimal(10, 2)
  totalDays            Int       @default(7) @map("total_days")
  courseThumbnail      String    @map("course_thumbnail")
  courseDescription    String    @map("course_description")
  problemStatementText String    @map("problem_statement_text")
  tags                 Json      @default("[]")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz()

  modules     CourseModule[]
  enrollments Enrollment[]

  @@index([slug])
  @@index([courseId])
  @@index([affiliatedBranch])
  @@index([isActive])
  @@index([deletedAt])
  @@map("courses")
}

model CourseModule {
  id            String   @id @default(cuid())
  courseId      String   @map("course_id")
  dayNumber     Int      @map("day_number")
  title         String   @db.VarChar(200)
  contentText   String   @map("content_text")
  transcriptText String? @map("transcript_text")
  notesPdfUrl   String?  @map("notes_pdf_url")
  youtubeUrl    String?  @map("youtube_url")
  isFreePreview Boolean  @default(false) @map("is_free_preview")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Restrict)
  quizQuestions QuizQuestion[]

  @@unique([courseId, dayNumber])
  @@index([courseId])
  @@index([isFreePreview])
  @@map("course_modules")
}

model QuizQuestion {
  id                 String @id @default(cuid())
  moduleId           String @map("module_id")
  questionText       String @map("question_text")
  options            Json // string[] e.g. ["Option A", "Option B", "Option C", "Option D"]
  correctOptionIndex Int    @map("correct_option_index")
  orderIndex         Int    @map("order_index")

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("quiz_questions")
}

// =============================================================================
// SECTION 4: ENROLLMENTS & PROGRESS
// =============================================================================

model Enrollment {
  id                        String        @id @default(cuid())
  userId                    String        @map("user_id")
  courseId                  String        @map("course_id")
  paymentStatus             PaymentStatus @default(pending) @map("payment_status")
  paymentGatewayOrderId     String?       @unique @map("payment_gateway_order_id") @db.VarChar(100)
  paymentGatewayPaymentId   String?       @map("payment_gateway_payment_id") @db.VarChar(100)
  amountPaid                Decimal       @map("amount_paid") @db.Decimal(10, 2)
  promocodeUsed             String?       @map("promocode_used") @db.VarChar(50)
  discountAmount            Decimal       @default(0.00) @map("discount_amount") @db.Decimal(10, 2)
  paymentMetadata           Json?         @map("payment_metadata")
  currentDay                Int           @default(1) @map("current_day")
  day7Completed             Boolean       @default(false) @map("day_7_completed")
  projectSubmissionDeadline DateTime?     @map("project_submission_deadline") @db.Timestamptz()
  // Certificate: stored as certificate_id on enrollment
  certificateId             String?       @unique @map("certificate_id") @db.VarChar(100)
  certificateIssued         Boolean       @default(false) @map("certificate_issued")
  isAdminGranted            Boolean       @default(false) @map("is_admin_granted")
  adminGrantedBy            String?       @map("admin_granted_by")
  adminGrantReason          String?       @map("admin_grant_reason")
  enrolledAt                DateTime      @default(now()) @map("enrolled_at") @db.Timestamptz()
  completedAt               DateTime?     @map("completed_at") @db.Timestamptz()
  updatedAt                 DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt                 DateTime?     @map("deleted_at") @db.Timestamptz()

  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Restrict)
  adminGranter    Admin?           @relation(fields: [adminGrantedBy], references: [id], onDelete: SetNull)
  dailyProgress   DailyProgress[]
  submission      Submission?
  transactions    Transaction[]
  promocodeUsages PromocodeUsage[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([paymentStatus])
  @@index([certificateId])
  @@index([deletedAt])
  @@map("enrollments")
}

model DailyProgress {
  id                String    @id @default(cuid())
  enrollmentId      String    @map("enrollment_id")
  dayNumber         Int       @map("day_number")
  isLocked          Boolean   @default(true) @map("is_locked")
  unlockedAt        DateTime? @map("unlocked_at") @db.Timestamptz()
  quizAttempted     Boolean   @default(false) @map("quiz_attempted")
  quizScore         Int       @default(0) @map("quiz_score")
  quizAnswers       Json?     @map("quiz_answers")
  quizPassed        Boolean   @default(false) @map("quiz_passed")
  quizAttempts      Int       @default(0) @map("quiz_attempts")
  quizCooldownUntil DateTime? @map("quiz_cooldown_until") @db.Timestamptz()
  startedAt         DateTime? @map("started_at") @db.Timestamptz()
  completedAt       DateTime? @map("completed_at") @db.Timestamptz()

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, dayNumber])
  @@index([enrollmentId])
  @@index([isLocked])
  @@map("daily_progress")
}

// =============================================================================
// SECTION 5: SUBMISSIONS & VERIFICATION
// =============================================================================

model Submission {
  id                         String         @id @default(cuid())
  enrollmentId               String         @unique @map("enrollment_id")
  userId                     String         @map("user_id")
  // Identity fields flattened here (removed identity_verifications table)
  fullName                   String         @map("full_name") @db.VarChar(200)
  dob                        DateTime?      @map("dob") @db.Date
  collegeName                String         @map("college_name") @db.VarChar(300)
  collegeIdLink              String         @map("college_id_link")
  branch                     String         @db.VarChar(50)
  graduationYear             Int            @map("graduation_year")
  // Project files: Drive link instead of R2
  driveLink                  String         @map("drive_link")
  // Removed: project_file_url, report_pdf_url, submission_versions
  reviewStatus               ReviewStatus   @default(pending) @map("review_status")
  assignedAdminId            String?        @map("assigned_admin_id")
  metric1SimulationAccuracy  Decimal?       @map("metric_1_simulation_accuracy") @db.Decimal(2, 1)
  metric2LogicMethodology    Decimal?       @map("metric_2_logic_methodology") @db.Decimal(2, 1)
  metric3IndustrialOutput    Decimal?       @map("metric_3_industrial_output") @db.Decimal(2, 1)
  metric4SensitivityAnalysis Decimal?       @map("metric_4_sensitivity_analysis") @db.Decimal(2, 1)
  metric5Documentation       Decimal?       @map("metric_5_documentation") @db.Decimal(2, 1)
  finalGrade                 Decimal?       @map("final_grade") @db.Decimal(3, 2)
  gradeCategory              GradeCategory? @map("grade_category")
  adminNotes                 String?        @map("admin_notes")
  resubmissionCount          Int            @default(0) @map("resubmission_count")
  maxResubmissions           Int            @default(2) @map("max_resubmissions")
  submittedAt                DateTime       @default(now()) @map("submitted_at") @db.Timestamptz()
  reviewStartedAt            DateTime?      @map("review_started_at") @db.Timestamptz()
  reviewCompletedAt          DateTime?      @map("review_completed_at") @db.Timestamptz()

  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  user          User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  assignedAdmin Admin?     @relation(fields: [assignedAdminId], references: [id], onDelete: SetNull)

  @@index([enrollmentId])
  @@index([userId])
  @@index([reviewStatus])
  @@index([assignedAdminId])
  @@map("submissions")
}

// =============================================================================
// SECTION 6: REFERRALS & PAYMENTS
// =============================================================================

model Referral {
  id               String         @id @default(cuid())
  referrerId       String         @map("referrer_id")
  refereeId        String         @map("referee_id")
  referralCodeUsed String         @map("referral_code_used") @db.VarChar(30)
  status           ReferralStatus @default(pending)
  amount           Decimal        @default(50.00) @db.Decimal(10, 2)
  registeredAt     DateTime       @default(now()) @map("registered_at") @db.Timestamptz()
  // Auto-approve after 7 days (set programmatically, not as DB default)
  autoApproveAt    DateTime?      @map("auto_approve_at") @db.Timestamptz()
  completedAt      DateTime?      @map("completed_at") @db.Timestamptz()
  // For rejection
  rejectionReason  String?        @map("rejection_reason")
  // Removed: payment_completed_at, withdrawal_eligible_at

  referrer     User          @relation("referralsSent", fields: [referrerId], references: [id], onDelete: Restrict)
  referee      User          @relation("referralsReceived", fields: [refereeId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([referrerId])
  @@index([refereeId])
  @@index([status])
  @@index([referralCodeUsed])
  @@index([autoApproveAt])
  @@map("referrals")
}

model WithdrawalRequest {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  amount          Decimal          @db.Decimal(10, 2)
  upiId           String           @map("upi_id") @db.VarChar(100)
  status          WithdrawalStatus @default(pending)
  adminConfirmed  Boolean          @default(false) @map("admin_confirmed")
  processedBy     String?          @map("processed_by")
  transactionId   String?          @map("transaction_id") @db.VarChar(100)
  rejectionReason String?          @map("rejection_reason")
  requestedAt     DateTime         @default(now()) @map("requested_at") @db.Timestamptz()
  processedAt     DateTime?        @map("processed_at") @db.Timestamptz()

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  processor    Admin?        @relation(fields: [processedBy], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@map("withdrawal_requests")
}

model Transaction {
  id                   String            @id @default(cuid())
  userId               String            @map("user_id")
  transactionType      TransactionType   @map("transaction_type")
  amount               Decimal           @db.Decimal(10, 2)
  paymentMethod        String?           @map("payment_method") @db.VarChar(50)
  enrollmentId         String?           @map("enrollment_id")
  referralId           String?           @map("referral_id")
  withdrawalRequestId  String?           @map("withdrawal_request_id")
  gatewayTransactionId String?           @map("gateway_transaction_id") @db.VarChar(100)
  gatewayStatus        String?           @map("gateway_status") @db.VarChar(50)
  status               TransactionStatus @default(pending)
  adminId              String?           @map("admin_id")
  reason               String?
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  user              User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  enrollment        Enrollment?        @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  referral          Referral?          @relation(fields: [referralId], references: [id], onDelete: SetNull)
  withdrawalRequest WithdrawalRequest? @relation(fields: [withdrawalRequestId], references: [id], onDelete: SetNull)
  admin             Admin?             @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([transactionType])
  @@index([status])
  @@index([createdAt])
  @@index([enrollmentId])
  @@map("transactions")
}

// =============================================================================
// SECTION 7: PROMOCODES
// =============================================================================

model Promocode {
  id            String       @id @default(cuid())
  code          String       @unique @db.VarChar(50)
  description   String?
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  maxDiscount   Decimal?     @map("max_discount") @db.Decimal(10, 2)
  usageLimit    Int?         @map("usage_limit")
  usageCount    Int          @default(0) @map("usage_count")
  perUserLimit  Int          @default(1) @map("per_user_limit")
  validFrom     DateTime     @map("valid_from") @db.Timestamptz()
  validUntil    DateTime     @map("valid_until") @db.Timestamptz()
  isActive      Boolean      @default(true) @map("is_active")
  createdBy     String?      @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz()

  creator Admin?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  usages  PromocodeUsage[]

  @@index([code])
  @@index([isActive])
  @@index([validFrom, validUntil])
  @@map("promocodes")
}

model PromocodeUsage {
  id              String   @id @default(cuid())
  promocodeId     String   @map("promocode_id")
  userId          String   @map("user_id")
  enrollmentId    String   @map("enrollment_id")
  discountApplied Decimal  @map("discount_applied") @db.Decimal(10, 2)
  usedAt          DateTime @default(now()) @map("used_at") @db.Timestamptz()

  promocode  Promocode  @relation(fields: [promocodeId], references: [id], onDelete: Restrict)
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([promocodeId])
  @@index([userId, promocodeId])
  @@map("promocode_usage")
}

// =============================================================================
// SECTION 8: PLATFORM
// =============================================================================

model SystemSetting {
  id           String   @id @default(cuid())
  settingKey   String   @unique @map("setting_key") @db.VarChar(100)
  settingValue Json     @map("setting_value")
  description  String?
  updatedBy    String?  @map("updated_by")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  updater Admin? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([settingKey])
  @@map("system_settings")
}

model WebhookLog {
  id              String        @id @default(cuid())
  // razorpay_order_id for atomic idempotency (UNIQUE constraint)
  razorpayOrderId String?       @unique @map("razorpay_order_id") @db.VarChar(100)
  webhookType     String        @map("webhook_type") @db.VarChar(50)
  payload         Json
  status          WebhookStatus
  errorMessage    String?       @map("error_message")
  processedAt     DateTime      @default(now()) @map("processed_at") @db.Timestamptz()

  @@index([webhookType, status])
  @@index([processedAt])
  @@map("webhook_logs")
}
